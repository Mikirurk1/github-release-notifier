{
  "name": "github-release-notifier",
  "version": "1.0.0",
  "description": "Monolithic REST API for GitHub release email notifications",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "build:public-css": "sass public/assets/styles/main.scss public/assets/styles/main.min.css --style=compressed --no-source-map",
    "build": "npm run prisma:generate && npm run build:public-css && tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prisma:generate": "prisma generate --config=./prisma.config.mjs",
    "prisma:migrate:deploy": "prisma migrate deploy --config=./prisma.config.mjs",
    "prisma:migrate:reset": "prisma migrate reset --config=./prisma.config.mjs --force"
  },
  "keywords": [
    "express",
    "prisma",
    "postgres",
    "github",
    "release",
    "notifications"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.12.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "ioredis": "^5.8.2",
    "nodemailer": "^7.0.9",
    "pg": "^8.20.0",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "prisma": "^7.7.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^7.0.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "sass": "^1.93.3",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1"
  }
}
