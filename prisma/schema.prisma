generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subscription {
  id                String   @id @default(uuid()) @db.Uuid
  email             String
  repo              String
  lastSeenTag       String?
  unsubscribeToken  String?  @unique
  createdAt         DateTime @default(now())

  @@unique([email, repo])
}
